{
  "name": "@noisia/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:smoke:migrations": "tsx scripts/smoke-migrations.ts",
    "db:smoke:local": "tsx scripts/smoke-local.ts",
    "db:apply:existing": "tsx scripts/apply-existing-migrations.ts",
    "db:verify:readiness": "tsx scripts/verify-live-intelligence-readiness.ts",
    "db:seed:methodologies": "tsx seeds/methodologies-only.ts",
    "db:seed": "tsx seeds/index.ts",
    "db:verify": "tsx seeds/verify.ts",
    "lint": "echo \"No lint configured for @noisia/db yet\"",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx migrations/*.test.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.0",
    "pg": "^8.13.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
