{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @noisia/workers build",
    "watchPatterns": [
      "services/workers/**",
      "packages/**",
      "infrastructure/db/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "package.json",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @noisia/workers start",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10
  }
}
