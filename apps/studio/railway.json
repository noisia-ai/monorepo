{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @noisia/studio build",
    "watchPatterns": [
      "apps/studio/**",
      "packages/**",
      "infrastructure/db/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "package.json",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @noisia/studio start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
