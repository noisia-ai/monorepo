# DATABASE (Supabase)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
DATABASE_URL=postgresql://postgres:xxx@db.xxxx.supabase.co:5432/postgres

# AUTH (Kinde)
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
KINDE_ISSUER_URL=https://noisiastudio.kinde.com
KINDE_SITE_URL=http://localhost:3001
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3001
# Debe apuntar a /auth/continue: esa página decide el destino por rol
# (internos -> /studio, clientes -> /signal). No la pongas en /studio.
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3001/auth/continue

# LLM (Anthropic + optional OpenAI fallback)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_FALLBACK=
OPENAI_API_KEY=

# QUEUE (Redis)
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# STORAGE (Supabase Storage)
SUPABASE_STORAGE_BUCKET_OUTPUTS=outputs
SUPABASE_STORAGE_BUCKET_CORPUS_FILES=corpus-files
SUPABASE_STORAGE_BUCKET_AVATARS=avatars

# EMAIL (Resend)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Noisia Studio <team@hey.noisia.ai>

# MONITORING
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=

# APP CONFIG
NEXT_PUBLIC_APP_NAME=Noisia Studio
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
NOISIA_INTERNAL_EMAIL_DOMAINS=noisia.ai
NOISIA_BOOTSTRAP_FOUNDER_EMAILS=
# Optional: map Kinde organization code to Noisia organization slug.
# Format: org_abc:seguros-el-potosi-demo,org_xyz:another-client
NOISIA_KINDE_ORG_MAP=
NODE_ENV=development

# FEATURE FLAGS
FEATURE_WHATSAPP=false
FEATURE_MULTI_COUNTRY=false
FEATURE_BILLING=false
# Engine methodology beta runtime. Keep false in prod until migrations, seeds,
# tests and smoke QA pass. LLM coding requires the second flag too.
NOISIA_ENGINE_RUNTIME_ENABLED=false
NOISIA_ENGINE_LLM_ENABLED=false
NOISIA_ENGINE_ALLOW_OPUS=false
NOISIA_ENGINE_FIXTURE_CODING_ENABLED=false
ENGINE_ALLOW_DETERMINISTIC_SYNTHESIS=false
# Internal-only technical methodology panel. Production ignores this flag even if true.
NOISIA_SHOW_ENGINE_BETA_PANEL=false
# Signal corpus chat synthesis. Keep false until report QA confirms retrieval,
# permissions and client-safe evidence.
NOISIA_SIGNAL_CHAT_LLM_ENABLED=false
NOISIA_SIGNAL_CHAT_ALLOW_OPUS=false
# Data OS foundation. Keep serving/tagging/backfill off in production until
# migrations, backfill, readiness verification and shadow QA pass.
NOISIA_DATA_OS_ENABLED=false
NOISIA_DATA_OS_BACKFILL_ENABLED=false
NOISIA_DATA_OS_SERVING_ENABLED=false
NOISIA_DATA_OS_TAGGING_ENABLED=false
NOISIA_DATA_OS_SHADOW_MODE=true
NOISIA_SIGNAL_PULSE_LIVE_API_ENABLED=false
NOISIA_SIGNAL_PULSE_LIVE_RENDER_ENABLED=false
NOISIA_DATA_OS_WORKER_ENABLED=false
NOISIA_SIGNAL_REFRESH_SCHEDULER_ENABLED=false
NOISIA_SIGNAL_INTERPRETATIONS_ENABLED=false
NOISIA_SIGNAL_INTERPRETATIONS_LLM_ENABLED=false
NOISIA_SIGNAL_INTERPRETATION_BUDGET_CAP_USD=0
NOISIA_SIGNAL_WORKSPACE_API_ENABLED=false
NOISIA_SIGNAL_AD_HOC_MATERIALIZATION_ENABLED=false
NOISIA_DATA_OS_WORKER_RUNS_ENABLED=false
NOISIA_DATA_OS_WORKER_REMOTE_APPROVED=false
NOISIA_DATA_OS_WORKER_CONCURRENCY=1
NOISIA_DATA_OS_QUEUE_NAME=
NOISIA_DATA_OS_BACKFILL_ALLOW_REMOTE=false
NOISIA_DATA_OS_ANALYZE_ALLOW_REMOTE=false
NOISIA_DATA_OS_CANDIDATES_ALLOW_REMOTE=false
NOISIA_DATA_OS_EVIDENCE_ALLOW_REMOTE=false
NOISIA_DATA_OS_PREFLIGHT_ALLOW_REMOTE=false
NOISIA_DATA_OS_PREFLIGHT_STRICT=false
NOISIA_DATA_OS_REVIEW_ALLOW_REMOTE=false
NOISIA_DATA_OS_REVIEW_QUEUE_ALLOW_REMOTE=false
NOISIA_DATA_OS_REVIEW_QUEUE_LIMIT=5
NOISIA_DATA_OS_REVIEW_QUEUE_SHOW_IDS=false
NOISIA_DATA_OS_REVIEW_QUEUE_SHOW_CONTEXT=false
NOISIA_DATA_OS_REVIEW_SAMPLE_APPROVED=false
NOISIA_DATA_OS_REVIEW_SAMPLE_AUTO_SELECT_LOCAL=false
NOISIA_DATA_OS_REVIEW_CORPUS_ID=
NOISIA_DATA_OS_REVIEW_TAG_ID=
NOISIA_DATA_OS_REVIEW_ASSERTION_ID=
NOISIA_DATA_OS_REVIEW_TAG_ACTION=approve
NOISIA_DATA_OS_REVIEW_ASSERTION_ACTION=approve
NOISIA_DATA_OS_REVIEWER_USER_ID=
NOISIA_DATA_OS_REVIEW_NOTES=
NOISIA_DATA_OS_RECONCILE_CORPUS_ID=
NOISIA_DATA_OS_RECONCILE_APPROVED=false
NOISIA_DATA_OS_RECONCILE_ALLOW_REMOTE=false
NOISIA_DATA_OS_SHADOW_ALLOW_REMOTE=false
NOISIA_DATA_OS_SHADOW_STRICT=false
NOISIA_DATA_OS_SHADOW_RUN_ENABLED=false
NOISIA_DATA_OS_SHADOW_RUN_STRICT=true
NOISIA_DATA_OS_SERVING_SMOKE_ALLOW_REMOTE=false
NOISIA_DATA_OS_BACKFILL_CORPUS_ID=
NOISIA_DATA_OS_SHADOW_OUTPUT_ID=
NOISIA_SIGNAL_WORKSPACE_ID=
NOISIA_SIGNAL_V2_BACKFILL_ALLOW_REMOTE=false
NOISIA_SIGNAL_V2_RECONCILE_ALLOW_REMOTE=false
NOISIA_SIGNAL_V2_EXPLAIN_ALLOW_REMOTE=false
NOISIA_SIGNAL_V2_EXPLAIN_ANALYZE=false
NOISIA_SIGNAL_V2_EXPLAIN_ANALYZE_REMOTE_APPROVED=false
NOISIA_SIGNAL_V2_SHADOW_ALLOW_REMOTE=false
NOISIA_DATA_OS_SERVING_SMOKE_CORPUS_ID=
NOISIA_DATA_OS_SERVING_SMOKE_OUTPUT_ID=
NOISIA_DATA_OS_STAGING_SHADOW_APPROVED=false
NOISIA_SIGNAL_V2_BACKFILL_APPROVED=false
NOISIA_DATA_OS_STAGING_SHADOW_APPLY_SCHEMA=false
NOISIA_DATA_OS_STAGING_SHADOW_SKIP_CANDIDATES=false
NOISIA_DATA_OS_EVIDENCE_PACK_DIR=
NOISIA_DATA_OS_LOCAL_SMOKE_EVIDENCE_DIR=
NOISIA_DATA_OS_STAGING_EVIDENCE_DIR=
NOISIA_DATA_OS_SMOKE_ALLOW_REMOTE=false
NOISIA_DATA_OS_VERIFY_DB=false
NOISIA_DATA_OS_VERIFY_ALLOW_REMOTE=false
# Remote DB writes. Keep false unless the target is isolated staging/throwaway/preview.
# Safety guards reject remote DATABASE_URL values with prod/production markers.
NOISIA_REMOTE_DATABASE_TARGET=
NOISIA_DB_APPLY_EXISTING_ALLOW_REMOTE=false
NOISIA_DB_SEED_ALLOW_REMOTE=false

# PIPELINE
QUERY_ENGINE_MAX_ITERATIONS=5
QUERY_ENGINE_SAMPLE_SIZE_PER_ITERATION=50
ANALYSIS_PIPELINE_TIMEOUT_SECONDS=900
